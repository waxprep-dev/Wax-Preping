import json
from typing import Dict, Any

from app.config import get_settings
from app.redis_client import get_redis
from app.security import security
from app.webhook_handler import MessageClassifier

settings = get_settings()


class StreamPublisher:
    def __init__(self):
        self.prefix = settings.REDIS_STREAM_PREFIX
    
    async def publish(self, normalized_event: Dict[str, Any], raw_payload: str) -> str:
        redis = await get_redis()
        
        # Determine stream
        stream_type = MessageClassifier.classify(json.loads(raw_payload))
        stream_name = f"{self.prefix}:{stream_type}"
        
        # Encrypt payload before entering Redis
        sealed_raw = security.seal_payload(raw_payload)
        sealed_normalized = security.seal_payload(json.dumps(normalized_event))
        
        message = {
            "wax_id": normalized_event["wax_id"],
            "message_id": normalized_event.get("message_id", ""),
            "event_type": normalized_event["event_type"],
            "trace_id": normalized_event["trace_id"],
            "timestamp": normalized_event["timestamp"],
            "sealed_raw": sealed_raw,
            "sealed_normalized": sealed_normalized,
            "stream_type": stream_type
        }
        
        # Add to stream with maxlen to prevent unbounded growth
        message_id = await redis.xadd(
            stream_name,
            message,
            maxlen=10000,
            approximate=True
        )
        
        return stream_name, message_id
    
    async def publish_retry(self, normalized_event: Dict[str, Any], attempt: int) -> None:
        redis = await get_redis()
        stream_name = f"{self.prefix}:retry"
        
        delay = min(
            settings.RETRY_BASE_DELAY * (2 ** attempt) + __import__('random').uniform(0, 1),
            3600
        )
        
        # Use Redis sorted set for delayed execution
        score = __import__('time').time() + delay
        payload = json.dumps({
            "event": normalized_event,
            "attempt": attempt,
            "execute_after": score
        })
        
        await redis.zadd(f"{stream_name}:scheduled", {security.seal_payload(payload): score})
    
    async def publish_overflow(self, normalized_event: Dict[str, Any], raw_payload: str) -> None:
        """When Redis is down, we still need to queue. This goes to DB sweeper."""
        pass  # Handled in main.py graceful degradation


publisher = StreamPublisher()
