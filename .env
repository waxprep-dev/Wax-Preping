# WhatsApp
WHATSAPP_VERIFY_TOKEN=your_verify_token
WHATSAPP_APP_SECRET=your_app_secret
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_access_token

# Cloud LLM providers (fallback when on-premise is offline)
GROQ_API_KEY=your_groq_key
OPENROUTER_API_KEY=your_openrouter_key

# On-premise models (set via docker-compose)
LLAMA_BRAIN_URL=http://localhost:8080
LLAMA_ROUTER_URL=http://localhost:8081

# Search
BRAVE_SEARCH_API_KEY=your_brave_key
TAVILY_API_KEY=your_tavily_key

# Voice (optional)
OPENAI_API_KEY=your_openai_key
ELEVENLABS_API_KEY=your_elevenlabs_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Embeddings
HF_API_KEY=your_huggingface_key

# Database
DATABASE_URL=postgresql://waxprep:waxprep@localhost:5432/waxprep
REDIS_URL=redis://localhost:6379

# Admin
ADMIN_KEY=your_secret_admin_key
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Student defaults
DEFAULT_STUDENT_TIMEZONE=Africa/Lagos
DEFAULT_STUDENT_REGION=NG

# Code interpreter (sandbox)
CODE_INTERPRETER_ENABLED=true
CODE_INTERPRETER_TIMEOUT_MS=15000
CODE_INTERPRETER_MAX_OUTPUT=8192

# Models (fast tier for perception/routing, smart tier for deliberation/generation)
MODEL_FAST_PROVIDER=groq
MODEL_FAST_NAME=llama-3.3-70b-versatile
MODEL_SMART_PROVIDER=openrouter
MODEL_SMART_NAME=anthropic/claude-3.5-sonnet
MODEL_DEEP_PROVIDER=openrouter
MODEL_DEEP_NAME=anthropic/claude-3.5-sonnet

# Neo4j (optional graph backend)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# On-premise AI (optional)
ZAI_API_KEY=your_zai_key